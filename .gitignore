# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# macOS / OS junk
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Build artifacts (regenerable from build.sh)
examples/sample-deck-inline.html
templates/slide-recipes.html

# Local user uploads / scratch (not part of the skill)
uploads/
thumbs/
thmx_unpacked/
screenshots/
*.thmx

# Scratch / per-invocation temp state (e.g. skills/feishu-deck-h5/tmp/slide-library/
# ppt-uploads.json registry — points at ephemeral /tmp sources, never source). Any level.
tmp/

# Per-invocation outputs from new-run.sh / render.py — regenerable, and
# often contain large user-provided scene images. Keep out of source.
runs/

# Rendered example output (regenerate from the tracked phase-1c-extras.json
# via render-deck.py). The .json is the source; the -out/ dir is an artifact.
phase-1c-extras-out/

# Skill distribution artifacts from package-skill.sh — regenerable,
# binary, dated. Don't commit. (.tar.gz + dist/ are the lean-package
# outputs; the dated .zip are the older full-repo snapshots.)
feishu-deck-h5-*.zip
feishu-deck-h5-*.tar.gz
dist/

# Node (if you ever add tooling)
node_modules/
package-lock.json

# Backup files — *.bak alone misses dated snapshots like
# `SKILL.md.bak-pre-slim-20260529` / `feishu-deck.css.bak-pre-l3-sweep-...`
# (they end in the date, not in `.bak`), so match the `.bak-*` suffix too.
*.bak
*.bak-*
*.orig
*~

# Preflight cache (per-machine cross-clone search results) + the RO-mount
# bootstrap workspace preflight.sh mirrors into when the skill is mounted
# read-only (Mira et al.). Both are per-machine + regenerable.
.feishu-deck-h5-preflight-cache
.feishu-deck-h5-workspace/

# Python virtualenvs — e.g. pptx-to-html/.venv (108MB, darwin/python3.x-specific,
# regenerable from requirements). Never commit a materialized env.
.venv/
venv/
env/

# pptx-to-deck skill: ignore the heavy regenerable assets (689MB of extracted
# slide images) + scratch dirs. Keep the lightweight evidence (deck.json, *.md,
# montage_*.png, index.html) tracked. (Belt-and-suspenders: the skill also ships
# its own local skills/pptx-to-deck/.gitignore.)
skills/pptx-to-deck/out/
skills/pptx-to-deck/example/**/assets/
skills/pptx-to-deck/example/**/sweep/
